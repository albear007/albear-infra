# albear-infra deployment secrets — copy to .env and fill in.
# .env is gitignored; never commit it.

# SSH target for the production box
BOX_HOST=ubuntu@x.x.x.x
SSH_KEY=~/.ssh/oci_key

# Local directory containing cert.pem + key.pem (Cloudflare Origin Cert).
# Required only for `just refresh-certs`. Leave blank otherwise.
CERT_LOCAL_PATH=
