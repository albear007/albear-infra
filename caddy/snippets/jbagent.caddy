agent.albeart.xyz {
    tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem
    encode zstd gzip
    reverse_proxy host.docker.internal:8000 {
        flush_interval -1
    }
}

telegram.albeart.xyz {
    tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem
    encode zstd gzip
    reverse_proxy host.docker.internal:8000 {
        flush_interval -1
    }
}
