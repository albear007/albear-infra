:80 {
    encode zstd gzip

    # User content (resume, avatar, demo videos, posters)
    @user_content path /static/*
    handle @user_content {
        root * /srv
        header Cache-Control "public, max-age=300, must-revalidate"
        file_server
    }

    # Backend API + health
    @api path /api/* /health
    handle @api {
        reverse_proxy backend:8000
    }

    # Legacy: keep /resume.pdf working (mirrors prod redirect)
    redir /resume.pdf /static/resume.pdf 301

    # Everything else → Vite dev server (HMR, index.html, frontend/public/*, source modules).
    # reverse_proxy auto-upgrades WebSocket so Vite HMR works through Caddy.
    reverse_proxy vite:5173
}
